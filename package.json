{
  "name": "ask-for-promise",
  "description": "promise utility library",
  "version": "3.1.0",
  "license": "MIT",
  "author": "Peter Naydenov",
  "main": "src/askForPromise.js",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/askForPromise.js",
      "require": "./dist/ask-for-promise.cjs",
      "default": "./src/askForPromise.js"
    },
    "./package.json": "./package.json",
    "./src/*": "./src/*",
    "./dist/*": "./dist/*",
    "./types/*": "./types/*"
  },
  "files": [
    "src/*.js",
    "dist/*",
    "types/*",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "test": "mocha test",
    "cover": "c8 mocha test",
    "build": "tsc --noEmit && rollup -c"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterNaydenov/ask-for-promise.git"
  },
  "homepage": "https://github.com/PeterNaydenov/ask-for-promise#readme",
  "bugs": {
    "url": "https://github.com/PeterNaydenov/ask-for-promise/issues"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/node": "^25.5.1",
    "c8": "^11.0.0",
    "chai": "6.2.2",
    "mocha": "^11.7.5",
    "rollup": "^4.60.1",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "glob": "^13.0.0",
    "minimatch": "^10.0.0",
    "brace-expansion": "^5.0.5",
    "diff": "^8.0.0",
    "serialize-javascript": "^7.0.0"
  },
  "directories": {
    "test": "test"
  },
  "c8": {
    "include": [
      "src/**/*.js"
    ],
    "exclude": [
      "node_modules",
      "test"
    ],
    "reporter": [
      "lcov",
      "text-summary"
    ]
  },
  "keywords": [
    "promise",
    "sequence",
    "paralel",
    "timout",
    "ttl",
    "decoupled promise"
  ]
}
